{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open-design",
  "mainBinaryName": "open-design",
  "version": "0.0.0",
  "identifier": "dev.opendesign.app",
  "build": {
    "beforeDevCommand": "vp dev --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "vp build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "open-design",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "category": "GraphicsAndDesign",
    "license": "Apache-2.0",
    "externalBin": [],
    "resources": []
  }
}
